POSTGRES_USER=deepref
POSTGRES_PASSWORD=deepref
POSTGRES_DB=deepref

NEO4J_AUTH=neo4j/deepref

# Browser-facing URL read by the web container at startup.
# Keep this as localhost for a single-machine self-hosted deployment.
PUBLIC_API_BASE_URL=http://localhost:8080

# Comma-separated browser origins allowed to call the API.
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Local testing escape hatch. Set to true only when host/port changes make the
# allowlist inconvenient. Do not use this for a public deployment.
API_CORS_ALLOW_ANY=false

RUST_LOG=info
