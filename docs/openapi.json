          "doi": {
            "type": "string"
          },
          "doi_key": {
            "type": "string"
          },
          "internal_citations": {
            "type": "integer",
            "format": "int32"
          },
          "issued_year": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "outbound_internal_references": {
            "type": "integer",
            "format": "int32"
          },
          "rank_score": {
            "type": "number",
            "format": "double"
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "total_citations": {
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "CreateIngestion": {
        "type": "object",
        "required": [
          "project_id",
          "seed_dois"
        ],
        "properties": {
          "citation_provider": {
            "type": [
              "string",
              "null"
